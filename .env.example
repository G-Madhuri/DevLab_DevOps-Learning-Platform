# DevLab Environment Variables
# Copy this file to .env and fill in values before running local services or docker-compose

# Database (Neon PostgreSQL or Local PostgreSQL)
DATABASE_URL=postgresql://your_user:your_password@your_host:5432/your_db?sslmode=require

# JWT Secrets — change these in production!
JWT_SECRET=your_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Upstash Redis REST Credentials
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here
