# DevLab Environment Variables
# Copy this file to .env and fill in values before running docker-compose

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://your_user:your_password@your_host:5432/your_db?sslmode=require

# JWT Secret — change this in production!
JWT_SECRET=your_jwt_secret_key_here

# Frontend API URL (for Docker Compose, use service name)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
